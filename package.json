{
  "name": "maid",
  "main": "expo-router/entry",
  "version": "3.0.0",
  "build": 2776,
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "prebuild": "expo prebuild --platform android --clean",
    "build-android": "export NODE_ENV=production JAVA_HOME=$HOME/.local/jdks/jdk-21 ANDROID_HOME=$HOME/android-sdk ANDROID_SDK_ROOT=$HOME/android-sdk PATH=$HOME/.local/jdks/jdk-21/bin:$HOME/android-sdk/cmdline-tools/latest/bin:$HOME/android-sdk/platform-tools:$PATH; cd android && ./gradlew assembleRelease",
    "build-android-bundle": "export NODE_ENV=production JAVA_HOME=$HOME/.local/jdks/jdk-21 ANDROID_HOME=$HOME/android-sdk ANDROID_SDK_ROOT=$HOME/android-sdk PATH=$HOME/.local/jdks/jdk-21/bin:$HOME/android-sdk/cmdline-tools/latest/bin:$HOME/android-sdk/platform-tools:$PATH; cd android && ./gradlew bundleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --ci --detectOpenHandles --runInBand --forceExit",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo",
    "resolver": "react-native-worklets/jest/resolver.js",
    "setupFiles": [
      "<rootDir>/jest.env.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@novastera-oss/.*|expo-router|standard-navigation|escape-string-regexp|react-navigation|@react-navigation/.*|@material/material-color-utilities)"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp|svg)$": "<rootDir>/__tests__/utilities/file-mock.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx",
      "**/?(*.)+(test).ts",
      "**/?(*.)+(test).tsx"
    ]
  },
  "dependencies": {
    "@expo/log-box": "^56.0.14",
    "@expo/metro-runtime": "^56.0.17",
    "@expo/vector-icons": "^15.0.2",
    "@material/material-color-utilities": "^0.3.0",
    "@novastera-oss/react-native-markdown-display": "^8.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "buffer": "^6.0.3",
    "expo": "56.0.16",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.21",
    "expo-crypto": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.15",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.15",
    "expo-splash-screen": "~56.0.13",
    "expo-sqlite": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "message-nodes": "^1.0.8",
    "openai": "^5.23.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "dotenv": "^17.3.1",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "expo": {
    "autolinking": {
      "android": {
        "buildFromSource": [
          ".*"
        ]
      }
    }
  },
  "private": true,
  "resolutions": {
    "minimatch": ">=3.1.3",
    "@novastera-oss/react-native-markdown-display/expo-image": "~56.0.11",
    "@testing-library/jest-dom": "6.9.1",
    "react-native-screens": "4.25.2"
  }
}
