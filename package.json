{
  "name": "maid",
  "main": "expo-router/entry",
  "version": "3.0.0",
  "build": 2776,
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "build-android": "export JAVA_HOME=$HOME/.local/jdks/jdk-21 ANDROID_HOME=$HOME/android-sdk ANDROID_SDK_ROOT=$HOME/android-sdk PATH=$HOME/.local/jdks/jdk-21/bin:$HOME/android-sdk/cmdline-tools/latest/bin:$HOME/android-sdk/platform-tools:$PATH; cd android && ./gradlew assembleRelease",
    "build-android-bundle": "export JAVA_HOME=$HOME/.local/jdks/jdk-21 ANDROID_HOME=$HOME/android-sdk ANDROID_SDK_ROOT=$HOME/android-sdk PATH=$HOME/.local/jdks/jdk-21/bin:$HOME/android-sdk/cmdline-tools/latest/bin:$HOME/android-sdk/platform-tools:$PATH; cd android && ./gradlew bundleRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --ci --detectOpenHandles --runInBand --forceExit",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.env.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@novastera-oss/.*|expo-router|escape-string-regexp|react-navigation|@react-navigation/.*|@material/material-color-utilities)"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp|svg)$": "<rootDir>/__tests__/utilities/file-mock.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx",
      "**/?(*.)+(test).ts",
      "**/?(*.)+(test).tsx"
    ]
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.3.0",
    "@novastera-oss/react-native-markdown-display": "^8.1.1",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/native": "^7.0.14",
    "buffer": "^6.0.3",
    "expo": "53.0.22",
    "expo-application": "~6.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.7",
    "expo-crypto": "~14.1.5",
    "expo-device": "~7.1.4",
    "expo-document-picker": "~13.1.6",
    "expo-font": "~13.3.2",
    "expo-image": "~2.4.0",
    "expo-linking": "~7.1.7",
    "expo-localization": "~16.1.6",
    "expo-modules-autolinking": "~2.1.11",
    "expo-network": "~7.1.5",
    "expo-router": "~5.1.6",
    "expo-splash-screen": "~0.30.10",
    "expo-sqlite": "~15.2.14",
    "expo-system-ui": "~5.0.11",
    "message-nodes": "^1.0.8",
    "openai": "^5.23.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^18.3.0",
    "dotenv": "^17.3.1",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.14",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "expo": {
    "autolinking": {
      "android": {
        "buildFromSource": [
          ".*"
        ]
      }
    }
  },
  "private": true,
  "resolutions": {
    "minimatch": ">=3.1.3"
  }
}
